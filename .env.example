# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Polymarket ─────────────────────────────────────────────
POLY_PRIVATE_KEY=0xyour_polygon_wallet_private_key
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_passphrase
POLY_GAMMA_URL=https://gamma-api.polymarket.com
POLY_CLOB_URL=https://clob.polymarket.com

# ── Kalshi (cross-venue arb) ───────────────────────────────
KALSHI_API_KEY=your_kalshi_key
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ── Trading mode ───────────────────────────────────────────
LIVE_MODE=false
DRY_RUN_LOG_PATH=./storage/paper_trades.jsonl

# ── Risk (change carefully) ────────────────────────────────
MAX_STAKE_PER_MARKET_USD=10.0
MAX_TOTAL_EXPOSURE_USD=100.0
MIN_EDGE_THRESHOLD=0.05
MAX_RESOLVE_DAYS=5
KELLY_FRACTION=0.25

# ── Free data sources ─────────────────────────────────────
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
REDDIT_CLIENT_ID=your_reddit_app_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=polymarket-agent/1.0

# ── Storage ────────────────────────────────────────────────
SQLITE_PATH=./storage/agent.db
CHROMA_PATH=./storage/chroma_db

# ── Cycle ──────────────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=900
